# Polymarket AI Trading Bot — Environment Variables Template
# Copy this to .env and fill in your values

# ═══ POLYMARKET ═══
POLYGON_PRIVATE_KEY=your_polygon_private_key
FUNDER_ADDRESS=your_polymarket_proxy_wallet_address
SIGNATURE_TYPE=2
# CLOB_RELAY_URL=https://your-relay.workers.dev  # uncomment if geo-blocked

# ═══ TELEGRAM ═══
TELEGRAM_BOT_TOKEN=8676514414:AAFkpctT7N_g19zBYxFBJlORT9sD0KqAcE4
TELEGRAM_CHAT_ID=6373760432

# ═══ TRADING ═══
TRADING_MODE=paper
MIN_TRADE_USD=5
MAX_TRADE_USD=50
MAX_POSITION_USD=200
MAX_DAILY_TRADES=50
PAPER_BALANCE=1000

# ═══ AI / LLM (GPT-4o-mini is cheap + fast) ═══
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini

# ═══ NEWS FEEDS (free tiers available) ═══
# NEWS_API_KEY=your_newsapi_key          # newsapi.org
# NEWSDATA_API_KEY=your_newsdata_key      # newsdata.io
# GNEWS_API_KEY=your_gnews_key            # gnews.io

# ═══ YOUTUBE (for MrBeast/video prediction markets) ═══
# YOUTUBE_API_KEY=your_youtube_api_key

# ═══ FINANCE DATA ═══
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key
# FINNHUB_API_KEY=your_finnhub_key

# ═══ EDGE THRESHOLDS ═══
MIN_EDGE_PERCENT=5
HIGH_EDGE_PERCENT=15
CONFIRMED_EVENT_THRESHOLD=0.90
MIN_LIQUIDITY_USD=5000

# ═══ SCANNER ═══
SCAN_INTERVAL_SECONDS=120
SCAN_TAGS=politics,elections,finance,crypto,geopolitics,sports,science,entertainment,culture
